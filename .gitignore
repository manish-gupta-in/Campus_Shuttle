# ══════════════════════════════════════════════════════════════
#  Campus_Shuttle — .gitignore
# ══════════════════════════════════════════════════════════════

# ── ROS 2 Workspace Build Artifacts ──────────────────────────
av_ws/build/
av_ws/install/
av_ws/log/
av_ws/maps/

# ── Python Cache & Bytecode ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# ── Virtual Environments ──────────────────────────────────────
venv/
.venv/
env/
.env

# ── IDE / Editor Files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Test Output / Coverage ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Logs & Temporary Files ────────────────────────────────────
*.log
terminal.txt

# ── ROS colcon / ament specific ───────────────────────────────
COLCON_IGNORE
AMENT_IGNORE
devel/

# NOTE: pointcloud_map.pcd (198 MB) is tracked via Git LFS
# See .gitattributes for LFS configuration
