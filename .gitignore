# ══════════════════════════════════════════════════════════════
#  Campus_Shuttle — .gitignore
#  BITS Pilani Autonomous Shuttle Mission Control
# ══════════════════════════════════════════════════════════════

# ── Large Binary Map Assets (use Git LFS if needed) ──────────
map/pointcloud_map.pcd

# ── ROS 2 Workspace Build Artifacts ──────────────────────────
av_ws/build/
av_ws/install/
av_ws/log/

# ── Python Cache & Bytecode ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────────
venv/
.venv/
env/
.env
*.env

# ── IDE / Editor Files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Test Output / Coverage ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.junit.xml

# ── Logs & Temporary Files ────────────────────────────────────
*.log
terminal.txt
/tmp/

# ── OS-Specific Files ─────────────────────────────────────────
.DS_Store
*.stackdump

# ── ROS colcon / ament specific ───────────────────────────────
COLCON_IGNORE
AMENT_IGNORE

# ── System-level rosdep / catkin cruft ───────────────────────
devel/
.catkin_workspace

# ── Git LFS Tracking (managed separately via .gitattributes) ─
# pointcloud_map.pcd tracked by LFS if enabled
