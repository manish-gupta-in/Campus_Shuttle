# Git LFS — Large Binary File Tracking
*.pcd filter=lfs diff=lfs merge=lfs -text

# Line Endings
*.py    text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf

# Binary Assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
